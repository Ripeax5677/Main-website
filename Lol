const heroSubtitleEl = document.querySelector(".hero > div > p");
const heroPrimaryButton = document.querySelector(".hero-buttons .btn-primary");
const heroSecondaryButton = document.querySelector(".hero-buttons .btn:not(.btn-primary)");
const aboutTitleEl = document.querySelector("#about > h2");
const aboutHeadings = document.querySelectorAll("#about .about-text h3");
const aboutParagraphs = document.querySelectorAll("#about .about-text p");
const aboutSkillItems = document.querySelectorAll("#about .skill-item");
const projectsTitleEl = document.querySelector("#projects > h2");
const projectCards = document.querySelectorAll("#projects .project-card");
const contactTitleEl = document.querySelector("#contact > h2");
const contactFormTitleEl = document.querySelector("#contact .contact-form h3");
const contactNameLabel = document.querySelector('label[for="contactName"]');
const contactEmailLabel = document.querySelector('label[for="contactEmail"]');
const contactMessageLabel = document.querySelector('label[for="contactMessage"]');
const contactNameInput = document.getElementById("contactName");
const contactEmailInput = document.getElementById("contactEmail");
const contactMessageInput = document.getElementById("contactMessage");
const contactSubmitButton = document.querySelector("#contactForm button");
const linksHeadingEl = document.querySelector("#contact > div > div:nth-child(2) > h3");
const footerTextEl = document.querySelector("footer p");
const devtoolsGuard = document.getElementById("devtoolsGuard");
const devtoolsGuardTitle = document.querySelector("#devtoolsGuard h2");
const devtoolsGuardText = document.querySelector("#devtoolsGuard p");

let currentLanguage = "en";
let bootMessages = translations.en.bootMessages.slice();
let msgIndex = 0;
let bootInterval = null;
let devtoolsOpen = false;

function getTranslation() {
  return translations[currentLanguage] || translations.en;
}

function setDevtoolsGuard(active) {
  devtoolsOpen = active;
  document.body.classList.toggle("devtools-lock", active);
  devtoolsGuard.classList.toggle("active", active);
}

function bootSequence() {
  if (msgIndex < bootMessages.length) {
    statusEl.textContent = bootMessages[msgIndex++];
  }
}

function setNodeListText(nodeList, values) {
  values.forEach((value, index) => {
    if (nodeList[index]) {
      nodeList[index].textContent = value;
    }
  });
}

function applyLanguage(language) {
  currentLanguage = translations[language] ? language : "en";
  const text = getTranslation();

  document.documentElement.lang = currentLanguage;
  document.title = text.title;
  bootMessages = text.bootMessages.slice();
  msgIndex = 0;

  loginHeadingEl.textContent = text.loginHeading;
  setNodeListText(loginTextEl, [text.loginText, text.loginUser, text.loginKey]);
  accessScreenEl.textContent = text.accessGranted;
  setNodeListText(navLinks, text.nav);
  heroTitleEl.innerHTML = `${text.heroTitlePrefix} <span>404notfound</span>`;
  heroSubtitleEl.textContent = text.heroSubtitle;
  heroPrimaryButton.textContent = text.heroProjects;
  heroSecondaryButton.textContent = text.heroContact;
  aboutTitleEl.textContent = text.aboutTitle;
  setNodeListText(aboutHeadings, [text.aboutWho, text.aboutTech]);
  setNodeListText(aboutParagraphs, [text.aboutDesc1, text.aboutDesc2, text.aboutTechDesc]);
  setNodeListText(aboutSkillItems, text.skillItems);
  projectsTitleEl.textContent = text.projectsTitle;

  projectCards.forEach((card, index) => {
    const heading = card.querySelector("h3");
    const paragraph = card.querySelector("p");

    if (heading && paragraph) {
      paragraph.textContent = text.projectDescriptions[index] || paragraph.textContent;
    }
  });

  contactTitleEl.textContent = text.contactTitle;
  contactFormTitleEl.textContent = text.contactFormTitle;
  contactNameLabel.textContent = text.nameLabel;
  contactEmailLabel.textContent = text.emailLabel;
  contactMessageLabel.textContent = text.messageLabel;
  contactNameInput.placeholder = text.namePlaceholder;
  contactEmailInput.placeholder = text.emailPlaceholder;
  contactMessageInput.placeholder = text.messagePlaceholder;
  contactSubmitButton.textContent = text.sendButton;
  linksHeadingEl.textContent = text.linksTitle;
  footerTextEl.textContent = `© 2026 404notfound. ${text.footer}`;
  devtoolsGuardTitle.textContent = text.devtoolsTitle;
  devtoolsGuardText.textContent = text.devtoolsText;
  statusEl.textContent = bootMessages[0];
}

async function detectLanguageByCountry() {
  const controller = new AbortController();
  const timeoutId = setTimeout(() => controller.abort(), 1400);

  try {
    const response = await fetch("https://ipapi.co/json/", {
      signal: controller.signal,
      cache: "no-store"
    });

    if (!response.ok) {
      throw new Error(`Status ${response.status}`);
    }

    const data = await response.json();
    return data.country_code === "DE" ? "de" : "en";
  } catch (error) {
    console.error("Language detection failed:", error);
    return "en";
  } finally {
    clearTimeout(timeoutId);
  }
}

// ===== DEVTOOLS PROTECTION =====
document.addEventListener("contextmenu", (event) => {
  event.preventDefault();
});

document.addEventListener("keydown", (event) => {
  const key = event.key.toLowerCase();
  const isDevtoolsShortcut =
    event.key === "F12" ||
    (event.ctrlKey && event.shiftKey && ["i", "j", "c"].includes(key)) ||
    (event.ctrlKey && key === "u");

  if (isDevtoolsShortcut) {
    event.preventDefault();
    event.stopPropagation();
    return false;
  }
});

setInterval(() => {
  const widthThreshold = window.outerWidth - window.innerWidth > 160;
  const heightThreshold = window.outerHeight - window.innerHeight > 160;
  const detected = widthThreshold || heightThreshold;

  if (detected !== devtoolsOpen) {
    setDevtoolsGuard(detected);
  }
}, 500);

// ===== AUTO LOGIN FLOW =====
window.addEventListener("load", async () => {
  const language = await detectLanguageByCountry();
  applyLanguage(language);

  bootInterval = setInterval(bootSequence, 700);

  setTimeout(() => {
    document.getElementById("loginBox").classList.add("fade");

    setTimeout(() => {
      document.getElementById("bootOverlay").classList.add("hidden");
      document.getElementById("navbar").style.display = "flex";
      document.getElementById("main").classList.add("show");
      clearInterval(bootInterval);
    }, 800);
  }, 3500);
});

// ===== SMOOTH SCROLL FOR NAV LINKS =====
document.querySelectorAll('nav a, .hero-buttons a[href^="#"]').forEach(link => {
  link.addEventListener("click", (e) => {
    const href = link.getAttribute("href");
    if (href.startsWith("#")) {
      e.preventDefault();
      const target = document.querySelector(href);
      if (target) {
        target.scrollIntoView({ behavior: "smooth" });
      }
    }
  });
});

// ===== FORM SUBMISSION =====
const discordWebhookUrl = "https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN";

async function sendDiscordNotification(name, email, message) {
  const text = getTranslation();

  if (!discordWebhookUrl || discordWebhookUrl.includes("YOUR_WEBHOOK_ID")) {
    return;
  }

  const payload = {
    embeds: [
      {
        title: text.discordTitle,
        color: 65280,
        fields: [
          { name: text.discordName, value: name || "-", inline: true },
          { name: text.discordEmail, value: email || "-", inline: true },
          { name: text.discordMessage, value: message || "-" }
        ],
        timestamp: new Date().toISOString()
      }
    ]
  };

  try {
    await fetch(discordWebhookUrl, {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(payload)
    });
  } catch (error) {
    console.error(text.discordError, error);
  }
}

document.getElementById("contactForm").addEventListener("submit", async (e) => {
  e.preventDefault();

  const text = getTranslation();
  const name = contactNameInput.value.trim();
  const email = contactEmailInput.value.trim();
  const message = contactMessageInput.value.trim();

  if (!name || !email || !message) {
    alert(text.emptyFormAlert);
    return;
  }

  await sendDiscordNotification(name, email, message);

  alert(text.sentAlert);
  e.target.reset();
});
